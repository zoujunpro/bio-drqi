<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bio.drqi.ai.dao.mapper.AiIntentExampleMapper">

    <resultMap id="BaseResultMap" type="com.bio.drqi.ai.dao.domain.AiIntentExample">
        <id property="id" column="id" jdbcType="BIGINT"/>
        <result property="intentCode" column="intent_code" jdbcType="VARCHAR"/>
        <result property="exampleText" column="example_text" jdbcType="VARCHAR"/>
        <result property="status" column="status" jdbcType="VARCHAR"/>
        <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
        <result property="updateTime" column="update_time" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, intent_code, example_text, status, create_time, update_time
    </sql>

    <select id="selectActiveByIntentCode" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"/>
        from ai_intent_example
        where intent_code = #{intentCode,jdbcType=VARCHAR}
          and cast(status as char) in ('ACTIVE', '1')
        order by id asc
    </select>

    <select id="selectActiveByIntentCodes" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"/>
        from ai_intent_example
        where cast(status as char) in ('ACTIVE', '1')
        <if test="intentCodes != null and intentCodes.size() > 0">
          and intent_code in
          <foreach collection="intentCodes" item="intentCode" open="(" separator="," close=")">
              #{intentCode,jdbcType=VARCHAR}
          </foreach>
        </if>
        <if test="intentCodes == null or intentCodes.size() == 0">
          and 1 = 0
        </if>
        order by id asc
    </select>
</mapper>

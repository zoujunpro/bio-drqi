<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bio.drqi.ai.dao.mapper.AiMessageMapper">

    <resultMap id="BaseResultMap" type="com.bio.drqi.ai.dao.domain.AiMessage">
        <id property="id" column="id" jdbcType="BIGINT"/>
        <result property="sessionId" column="session_id" jdbcType="VARCHAR"/>
        <result property="userId" column="user_id" jdbcType="VARCHAR"/>
        <result property="role" column="role" jdbcType="VARCHAR"/>
        <result property="content" column="content" jdbcType="LONGVARCHAR"/>
        <result property="source" column="source" jdbcType="VARCHAR"/>
        <result property="difyMessageId" column="dify_message_id" jdbcType="VARCHAR"/>
        <result property="metadata" column="metadata" jdbcType="LONGVARCHAR"/>
        <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, session_id, user_id, role, content, source, dify_message_id, metadata, create_time
    </sql>

    <select id="selectRecentBySessionId" resultMap="BaseResultMap">
        select *
        from (
            select <include refid="Base_Column_List"/>
            from ai_message
            where session_id = #{sessionId,jdbcType=VARCHAR}
            order by id desc
            limit #{limit,jdbcType=INTEGER}
        ) t
        order by t.id asc
    </select>
</mapper>

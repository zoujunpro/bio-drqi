<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bio.drqi.ai.dao.mapper.AiSemanticPatternMapper">

    <resultMap id="BaseResultMap" type="com.bio.drqi.ai.dao.domain.AiSemanticPattern">
        <id property="id" column="id" jdbcType="BIGINT"/>
        <result property="patternType" column="pattern_type" jdbcType="VARCHAR"/>
        <result property="patternCode" column="pattern_code" jdbcType="VARCHAR"/>
        <result property="patternText" column="pattern_text" jdbcType="VARCHAR"/>
        <result property="targetValue" column="target_value" jdbcType="VARCHAR"/>
        <result property="weight" column="weight" jdbcType="DECIMAL"/>
        <result property="domain" column="domain" jdbcType="VARCHAR"/>
        <result property="status" column="status" jdbcType="VARCHAR"/>
        <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
        <result property="updateTime" column="update_time" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, pattern_type, pattern_code, pattern_text, target_value, weight, domain, status, create_time, update_time
    </sql>

    <select id="selectActiveByPatternType" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"/>
        from ai_semantic_pattern
        where cast(status as char) in ('ACTIVE', '1')
          and pattern_type = #{patternType,jdbcType=VARCHAR}
        order by weight desc, id asc
    </select>
</mapper>

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bio.drqi.ai.dao.mapper.AiTaskTemplateMapper">

    <resultMap id="BaseResultMap" type="com.bio.drqi.ai.dao.domain.AiTaskTemplate">
        <id property="id" column="id" jdbcType="BIGINT"/>
        <result property="templateCode" column="template_code" jdbcType="VARCHAR"/>
        <result property="templateName" column="template_name" jdbcType="VARCHAR"/>
        <result property="intentCode" column="intent_code" jdbcType="VARCHAR"/>
        <result property="domain" column="domain" jdbcType="VARCHAR"/>
        <result property="description" column="description" jdbcType="LONGVARCHAR"/>
        <result property="status" column="status" jdbcType="VARCHAR"/>
        <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
        <result property="updateTime" column="update_time" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, template_code, template_name, intent_code, domain, description, status, create_time, update_time
    </sql>

    <select id="selectActiveByIntentCode" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"/>
        from ai_task_template
        where intent_code = #{intentCode,jdbcType=VARCHAR}
          and cast(status as char) in ('ACTIVE', '1')
        order by id asc
        limit 1
    </select>
</mapper>

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bio.drqi.ai.dao.mapper.AiToolDefinitionMapper">

    <resultMap id="BaseResultMap" type="com.bio.drqi.ai.dao.domain.AiToolDefinition">
        <id property="id" column="id" jdbcType="BIGINT"/>
        <result property="toolCode" column="tool_code" jdbcType="VARCHAR"/>
        <result property="toolName" column="tool_name" jdbcType="VARCHAR"/>
        <result property="description" column="description" jdbcType="LONGVARCHAR"/>
        <result property="toolType" column="tool_type" jdbcType="VARCHAR"/>
        <result property="targetCode" column="target_code" jdbcType="VARCHAR"/>
        <result property="inputSchema" column="input_schema" jdbcType="LONGVARCHAR"/>
        <result property="outputSchema" column="output_schema" jdbcType="LONGVARCHAR"/>
        <result property="serviceUrl" column="service_url" jdbcType="VARCHAR"/>
        <result property="httpMethod" column="http_method" jdbcType="VARCHAR"/>
        <result property="riskLevel" column="risk_level" jdbcType="VARCHAR"/>
        <result property="readOnly" column="read_only" jdbcType="INTEGER"/>
        <result property="status" column="status" jdbcType="VARCHAR"/>
        <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
        <result property="updateTime" column="update_time" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, tool_code, tool_name, description, tool_type, target_code, input_schema, output_schema,
        service_url, http_method, risk_level, read_only, status, create_time, update_time
    </sql>

    <select id="selectByToolCode" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"/>
        from ai_tool_definition
        where tool_code = #{toolCode,jdbcType=VARCHAR}
        limit 1
    </select>

    <select id="selectActiveByToolCode" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"/>
        from ai_tool_definition
        where tool_code = #{toolCode,jdbcType=VARCHAR}
          and cast(status as char) in ('ACTIVE', '1')
        limit 1
    </select>

    <select id="selectActiveList" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"/>
        from ai_tool_definition
        where cast(status as char) in ('ACTIVE', '1')
        order by id asc
    </select>

    <select id="selectActiveByToolCodes" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"/>
        from ai_tool_definition
        where cast(status as char) in ('ACTIVE', '1')
        <if test="toolCodes != null and toolCodes.size() > 0">
          and tool_code in
          <foreach collection="toolCodes" item="toolCode" open="(" separator="," close=")">
              #{toolCode,jdbcType=VARCHAR}
          </foreach>
        </if>
        <if test="toolCodes == null or toolCodes.size() == 0">
          and 1 = 0
        </if>
        order by id asc
    </select>
</mapper>

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bio.drqi.mapper.BioAppletLoginTbMapper">

    <resultMap id="BaseResultMap" type="com.bio.drqi.domain.BioAppletLoginTb">
            <id property="id" column="id" jdbcType="INTEGER"/>
            <result property="appId" column="app_id" jdbcType="VARCHAR"/>
            <result property="openId" column="open_id" jdbcType="VARCHAR"/>
            <result property="telephone" column="telephone" jdbcType="VARCHAR"/>
            <result property="jobNum" column="job_num" jdbcType="VARCHAR"/>
            <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,app_id,open_id,
        telephone,job_num,create_time
    </sql>
    <select id="selectOneByTelephone" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from bio_applet_login_tb
        where
        telephone = #{telephone,jdbcType=VARCHAR}
    </select>
    <select id="selectOneByAppIdAndOpenId" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from bio_applet_login_tb
        where
        app_id = #{appId,jdbcType=VARCHAR}
        AND open_id = #{openId,jdbcType=VARCHAR}
    </select>
</mapper>

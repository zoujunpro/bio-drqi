<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bio.drqi.mapper.BmsProductCategoryTbMapper">

    <resultMap id="BaseResultMap" type="com.bio.drqi.domain.BmsProductCategoryTb">
        <id property="id" column="id" jdbcType="INTEGER"/>
        <result property="productCategoryName" column="product_category_name" jdbcType="VARCHAR"/>
        <result property="productCategoryCode" column="product_category_code" jdbcType="VARCHAR"/>
        <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
        <result property="createUserId" column="create_user_id" jdbcType="INTEGER"/>
        <result property="createUserName" column="create_user_name" jdbcType="VARCHAR"/>
        <result property="kdParentId" column="kd_parent_id" jdbcType="VARCHAR"/>
        <result property="kdParentName" column="kd_parent_name" jdbcType="VARCHAR"/>
        <result property="kdNumber" column="kd_number" jdbcType="INTEGER"/>

    </resultMap>

    <sql id="Base_Column_List">
        id
        ,product_category_name,product_category_code,
        create_time,create_user_id,create_user_name,kd_parent_id,kd_parent_name,kd_number
    </sql>
    <select id="selectOneByProductCategoryName" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from bms_product_category_tb
        where
        product_category_name = #{productCategoryName,jdbcType=VARCHAR}
    </select>
    <select id="selectSelective" parameterType="com.bio.drqi.domain.BmsProductCategoryTb" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from bms_product_category_tb
        <where>
            <if test="productCategoryName != null and productCategoryName !=''">and product_category_name LIKE
                CONCAT('%',#{productCategoryName,jdbcType=VARCHAR},'%')
            </if>
            <if test="productCategoryCode != null">and product_category_code=#{productCategoryCode,jdbcType=VARCHAR}
            </if>
            <if test="createTime != null">and create_time=#{createTime,jdbcType=TIMESTAMP}</if>
            <if test="createUserId != null">and create_user_id=#{createUserId,jdbcType=NUMERIC}</if>
            <if test="createUserName != null">and create_user_name=#{createUserName,jdbcType=VARCHAR}</if>
        </where>
        order by id desc
    </select>
</mapper>

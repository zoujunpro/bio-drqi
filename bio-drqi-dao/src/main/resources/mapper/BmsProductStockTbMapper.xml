<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bio.drqi.mapper.BmsProductStockTbMapper">

    <resultMap id="BaseResultMap" type="com.bio.drqi.domain.BmsProductStockTb">
            <id property="id" column="id" jdbcType="INTEGER"/>
            <result property="productName" column="product_name" jdbcType="VARCHAR"/>
            <result property="productOutCode" column="product_out_code" jdbcType="VARCHAR"/>
            <result property="productCategoryCode" column="product_category_code" jdbcType="VARCHAR"/>
            <result property="productCategoryName" column="product_category_name" jdbcType="VARCHAR"/>
            <result property="brandCode" column="brand_code" jdbcType="VARCHAR"/>
            <result property="brandName" column="brand_name" jdbcType="VARCHAR"/>
            <result property="productSpecs" column="product_specs" jdbcType="VARCHAR"/>
            <result property="batchNo" column="batch_no" jdbcType="VARCHAR"/>
            <result property="totalStoreNumber" column="total_store_number" jdbcType="INTEGER"/>
            <result property="currentStockNumber" column="current_stock_number" jdbcType="INTEGER"/>
            <result property="totalOutNumber" column="total_out_number" jdbcType="INTEGER"/>
            <result property="unitCode" column="unit_code" jdbcType="VARCHAR"/>
            <result property="stockLocationNumber" column="stock_location_number" jdbcType="VARCHAR"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,product_name,product_out_code,
        product_category_code,product_category_name,brand_code,
        brand_name,product_specs,batch_no,
        total_store_number,current_stock_number,total_out_number,
        unit_code,stock_location_number
    </sql>
    <select id="selectOneByBrandCodeAndProductSpecsAndProductNameAndBatchNoAndUnitCode" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from bms_product_stock_tb
        where
        brand_code = #{brandCode,jdbcType=VARCHAR}
        AND product_specs = #{productSpecs,jdbcType=VARCHAR}
        AND product_name = #{productName,jdbcType=VARCHAR}
        AND batch_no = #{batchNo,jdbcType=VARCHAR}
        AND unit_code = #{unitCode,jdbcType=VARCHAR}
    </select>
</mapper>

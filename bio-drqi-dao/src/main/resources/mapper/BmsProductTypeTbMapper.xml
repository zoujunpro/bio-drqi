<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bio.drqi.mapper.BmsProductTypeTbMapper">

    <resultMap id="BaseResultMap" type="com.bio.drqi.domain.BmsProductTypeTb">
        <id property="id" column="id" jdbcType="INTEGER"/>
        <result property="productTypeCode" column="product_type_code" jdbcType="VARCHAR"/>
        <result property="productTypeName" column="product_type_name" jdbcType="VARCHAR"/>
        <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
        <result property="createUserId" column="create_user_id" jdbcType="INTEGER"/>
        <result property="createUserName" column="create_user_name" jdbcType="VARCHAR"/>
    </resultMap>

    <sql id="Base_Column_List">
        id
        ,product_type_code,product_type_name,
        create_time,create_user_id,create_user_name
    </sql>
    <select id="selectSelective" resultMap="BaseResultMap" parameterType="com.bio.drqi.domain.BmsProductTypeTb">
        select
        <include refid="Base_Column_List"/>
        from
        bms_product_type_tb
        <where>
            <if test="productTypeCode != null">and product_type_code=#{productTypeCode,jdbcType=VARCHAR}</if>
            <if test="productTypeName != null and productTypeName != ''">and product_type_name LIKE  CONCAT('%',#{productTypeName,jdbcType=VARCHAR},'%')</if>
            <if test="createTime != null">and create_time=#{createTime,jdbcType=TIMESTAMP}</if>
            <if test="createUserId != null">and create_user_id=#{createUserId,jdbcType=NUMERIC}</if>
            <if test="createUserName != null">and create_user_name=#{createUserName,jdbcType=VARCHAR}</if>
        </where>
        order by id desc
    </select>
    <select id="selectOneByProductTypeName" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from bms_product_type_tb
        where
        product_type_name = #{productTypeName,jdbcType=VARCHAR}
    </select>
</mapper>

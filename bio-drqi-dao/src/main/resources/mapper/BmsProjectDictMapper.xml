<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bio.drqi.mapper.BmsProjectDictMapper">

    <resultMap id="BaseResultMap" type="com.bio.drqi.domain.BmsProjectDict">
            <id property="id" column="id" jdbcType="INTEGER"/>
            <result property="projectCode" column="project_code" jdbcType="VARCHAR"/>
            <result property="projectName" column="project_name" jdbcType="VARCHAR"/>
            <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
            <result property="createUserId" column="create_user_id" jdbcType="INTEGER"/>
            <result property="createUserName" column="create_user_name" jdbcType="VARCHAR"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,project_code,project_name,
        create_time,create_user_id,create_user_name
    </sql>
    <select id="selectAllOrderByIdDesc" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from bms_project_dict
        order by id desc
    </select>
    <select id="selectOneByProjectCode" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from bms_project_dict
        where
        project_code = #{projectCode,jdbcType=VARCHAR}
    </select>

</mapper>

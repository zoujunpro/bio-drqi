<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bio.drqi.mapper.BmsStockLocationDictMapper">

    <resultMap id="BaseResultMap" type="com.bio.drqi.domain.BmsStockLocationDict">
            <id property="id" column="id" jdbcType="INTEGER"/>

            <result property="unitCode" column="unit_code" jdbcType="VARCHAR"/>
            <result property="stockCode" column="stock_code" jdbcType="VARCHAR"/>
            <result property="stockName" column="stock_name" jdbcType="VARCHAR"/>
            <result property="locationNumber" column="location_number" jdbcType="VARCHAR"/>
            <result property="createUserId" column="create_user_id" jdbcType="INTEGER"/>
            <result property="createUserName" column="create_user_name" jdbcType="VARCHAR"/>
            <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,unit_code,stock_code,
        stock_name,location_number,create_user_id,
        create_user_name,create_time
    </sql>

    <select id="selectOneByUnitCodeAndLocationNumber" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from bms_stock_location_dict
        where
        unit_code = #{unitCode,jdbcType=VARCHAR}
        AND location_number = #{locationNumber,jdbcType=VARCHAR}
    </select>
    <select id="selectSelective" resultMap="BaseResultMap" parameterType="com.bio.drqi.domain.BmsStockLocationDict">
        select
        <include refid="Base_Column_List"/>
        from bms_stock_location_dict
        <where>
            <if test="unitCode != null and unitCode!=''">and unit_code=#{unitCode,jdbcType=VARCHAR}</if>
            <if test="stockCode != null and stockCode!=''">and stock_code=#{stockCode,jdbcType=VARCHAR}</if>
            <if test="stockName != null and stockName!=''">and stock_name=#{stockName,jdbcType=VARCHAR}</if>
            <if test="locationNumber != null and locationNumber!=''">and location_number=#{locationNumber,jdbcType=VARCHAR}</if>
            <if test="createUserId != null">and create_user_id=#{createUserId,jdbcType=NUMERIC}</if>
            <if test="createUserName != null">and create_user_name=#{createUserName,jdbcType=VARCHAR}</if>
            <if test="createTime != null">and create_time=#{createTime,jdbcType=TIMESTAMP}</if>
        </where>
        order by id desc
    </select>
    <select id="selectAllByStockName" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from bms_stock_location_dict
        where
        stock_name = #{stockName,jdbcType=VARCHAR}
    </select>
    <select id="selectOneByStockCodeAndLocationNumber" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from bms_stock_location_dict
        where
        stock_code = #{stockCode,jdbcType=VARCHAR}
        AND location_number = #{locationNumber,jdbcType=VARCHAR}
    </select>
    <select id="selectAllByStockCode" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from bms_stock_location_dict
        where
        stock_code = #{stockCode,jdbcType=VARCHAR}
    </select>
    <select id="selectAllByUnitCode" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from bms_stock_location_dict
        where
        unit_code = #{unitCode,jdbcType=VARCHAR}
    </select>
</mapper>

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bio.drqi.mapper.CerAcceptorMaterialDictMapper">

    <resultMap id="BaseResultMap" type="com.bio.drqi.domain.CerAcceptorMaterialDict">
            <id property="id" column="id" jdbcType="INTEGER"/>
            <result property="speciesCode" column="species_code" jdbcType="VARCHAR"/>
            <result property="acceptorMaterialName" column="acceptor_material_name" jdbcType="VARCHAR"/>
            <result property="acceptorMaterialCode" column="acceptor_material_code" jdbcType="VARCHAR"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,species_code,acceptor_material_name,
        acceptor_material_code
    </sql>
    <select id="selectOneByAcceptorMaterialCode" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from cer_acceptor_material_dict
        where
        acceptor_material_code = #{acceptorMaterialCode,jdbcType=VARCHAR}
    </select>
    <select id="selectAllBySpeciesCode" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from cer_acceptor_material_dict
        where
        species_code = #{speciesCode,jdbcType=VARCHAR}
    </select>
</mapper>

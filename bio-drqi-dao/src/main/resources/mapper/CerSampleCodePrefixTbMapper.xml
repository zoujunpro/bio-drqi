<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bio.drqi.mapper.CerSampleCodePrefixTbMapper">

    <resultMap id="BaseResultMap" type="com.bio.drqi.domain.CerSampleCodePrefixTb">
            <id property="id" column="id" jdbcType="INTEGER"/>
            <result property="sampleCodePrefix" column="sample_code_prefix" jdbcType="VARCHAR"/>
            <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
            <result property="vectorTaskCode" column="vector_task_code" jdbcType="VARCHAR"/>
            <result property="plantExperimentCode" column="plant_experiment_code" jdbcType="VARCHAR"/>

    </resultMap>

    <sql id="Base_Column_List">
        id,sample_code_prefix,create_time,
        vector_task_code
    </sql>
    <select id="selectOneByVectorTaskCode" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from cer_sample_code_prefix_tb
        where
        vector_task_code = #{vectorTaskCode,jdbcType=VARCHAR}
    </select>
    <delete id="deleteByVectorTaskCode">
        delete
        from cer_sample_code_prefix_tb
        where vector_task_code = #{vectorTaskCode,jdbcType=VARCHAR}
    </delete>
    <select id="selectAllByPlantExperimentCode" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from cer_sample_code_prefix_tb
        where
        plant_experiment_code = #{plantExperimentCode,jdbcType=VARCHAR}
    </select>
</mapper>

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bio.drqi.mapper.CerSampleTestBioInfoResultTbMapper">

    <resultMap id="BaseResultMap" type="com.bio.drqi.domain.CerSampleTestBioInfoResultTb">
            <id property="id" column="id" jdbcType="INTEGER"/>
            <result property="applyNo" column="apply_no" jdbcType="VARCHAR"/>
            <result property="sampleCode" column="sample_code" jdbcType="VARCHAR"/>
            <result property="vectorTaskCode" column="vector_task_code" jdbcType="VARCHAR"/>
            <result property="sampleId" column="sample_id" jdbcType="VARCHAR"/>
            <result property="uniqueDbCode" column="unique_db_code" jdbcType="VARCHAR"/>
            <result property="runId" column="run_id" jdbcType="VARCHAR"/>
            <result property="hapId" column="hap_id" jdbcType="VARCHAR"/>
            <result property="varType" column="var_type" jdbcType="VARCHAR"/>
            <result property="mutate" column="mutate" jdbcType="VARCHAR"/>
            <result property="ratio" column="ratio" jdbcType="VARCHAR"/>
            <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
            <result property="confirmStatus" column="confirm_status" jdbcType="VARCHAR"/>
            <result property="resultKey" column="result_key" jdbcType="VARCHAR"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,apply_no,sample_code,
        vector_task_code,sample_id,unique_db_code,
        run_id,hap_id,var_type,
        mutate,ratio,create_time,
        confirm_status,result_key
    </sql>
    <delete id="deleteByApplyNoAndSampleCode">
        delete
        from cer_sample_test_bio_info_result_tb
        where apply_no = #{applyNo,jdbcType=VARCHAR}
          AND sample_code = #{sampleCode,jdbcType=VARCHAR}
    </delete>
    <select id="selectAllByApplyNoAndSampleCodeIn" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from cer_sample_test_bio_info_result_tb
        where
        apply_no = #{applyNo,jdbcType=VARCHAR}
        AND sample_code in
        <foreach collection="sampleCodeList" item="item" open="(" close=")" separator=",">
            #{item,jdbcType=VARCHAR}
        </foreach>
    </select>
    <delete id="deleteByApplyNo">
        delete
        from cer_sample_test_bio_info_result_tb
        where apply_no = #{applyNo,jdbcType=VARCHAR}
    </delete>
</mapper>

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bio.drqi.mapper.CerSampleTestBioResultRefMapper">

    <resultMap id="BaseResultMap" type="com.bio.drqi.domain.CerSampleTestBioResultRef">
            <id property="id" column="id" jdbcType="INTEGER"/>
            <result property="applyNo" column="apply_no" jdbcType="VARCHAR"/>
            <result property="sampleCode" column="sample_code" jdbcType="VARCHAR"/>
            <result property="vectorTaskCode" column="vector_task_code" jdbcType="VARCHAR"/>
            <result property="sampleId" column="sample_id" jdbcType="VARCHAR"/>
            <result property="runId" column="run_id" jdbcType="VARCHAR"/>
            <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,apply_no,sample_code,
        vector_task_code,sample_id,run_id,
        create_time
    </sql>
    <delete id="deleteByApplyNo">
        delete
        from cer_sample_test_bio_result_ref
        where apply_no = #{applyNo,jdbcType=VARCHAR}
    </delete>
    <insert id="insertBatch">
        insert into cer_sample_test_bio_result_ref(id,apply_no,sample_code,
        vector_task_code,sample_id,run_id,
        create_time)
        values
        <foreach collection="cerSampleTestBioResultRefCollection" item="item" separator=",">
            (#{item.id,jdbcType=NUMERIC},#{item.applyNo,jdbcType=VARCHAR},#{item.sampleCode,jdbcType=VARCHAR},
            #{item.vectorTaskCode,jdbcType=VARCHAR},#{item.sampleId,jdbcType=VARCHAR},#{item.runId,jdbcType=VARCHAR},
            #{item.createTime,jdbcType=TIMESTAMP})
        </foreach>
    </insert>
</mapper>

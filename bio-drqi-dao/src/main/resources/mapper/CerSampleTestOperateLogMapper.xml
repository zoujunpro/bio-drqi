<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bio.drqi.mapper.CerSampleTestOperateLogMapper">

    <resultMap id="BaseResultMap" type="com.bio.drqi.domain.CerSampleTestOperateLog">
            <id property="id" column="id" jdbcType="BIGINT"/>
            <result property="projectCode" column="project_code" jdbcType="VARCHAR"/>
            <result property="vectorTaskCode" column="vector_task_code" jdbcType="VARCHAR"/>
            <result property="projectId" column="project_id" jdbcType="INTEGER"/>
            <result property="vectorTaskId" column="vector_task_id" jdbcType="INTEGER"/>
            <result property="sampleCode" column="sample_code" jdbcType="VARCHAR"/>
            <result property="operateCode" column="operate_code" jdbcType="VARCHAR"/>
             <result property="uniqueCode" column="unique_code" jdbcType="VARCHAR"/>
            <result property="remark" column="remark" jdbcType="VARCHAR"/>
            <result property="pictureUrls" column="picture_urls" jdbcType="VARCHAR"/>
            <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
            <result property="createUserId" column="create_user_id" jdbcType="INTEGER"/>
            <result property="createUserName" column="create_user_name" jdbcType="VARCHAR"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,project_code,vector_task_code,
        project_id,vector_task_id,sample_code,
        operate_code,unique_code,remark,picture_urls,
        create_time,create_user_id,create_user_name
    </sql>
    <select id="selectOneByUniqueCode" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from cer_sample_test_operate_log
        where
        unique_code = #{uniqueCode,jdbcType=VARCHAR}
    </select>
    <select id="selectOneBySampleCode" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from cer_sample_test_operate_log
        where
        sample_code = #{sampleCode,jdbcType=VARCHAR}
    </select>
</mapper>

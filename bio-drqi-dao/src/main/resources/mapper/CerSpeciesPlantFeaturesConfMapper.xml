<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bio.drqi.mapper.CerSpeciesPlantFeaturesConfMapper">

    <resultMap id="BaseResultMap" type="com.bio.drqi.domain.CerSpeciesPlantFeaturesConf">
            <id property="id" column="id" jdbcType="INTEGER"/>
            <result property="speciesCode" column="species_code" jdbcType="VARCHAR"/>
            <result property="plantFeaturesName" column="plant_features_name" jdbcType="VARCHAR"/>
            <result property="plantFeaturesDesc" column="plant_features_desc" jdbcType="VARCHAR"/>
            <result property="orderNum" column="order_num" jdbcType="INTEGER"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,species_code,plant_features_name,
        plant_features_desc,order_num
    </sql>
    <select id="selectAllBySpeciesCodeOrderByOrderNum" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from cer_species_plant_features_conf
        where
        species_code = #{speciesCode,jdbcType=VARCHAR}
        order by order_num
    </select>
</mapper>

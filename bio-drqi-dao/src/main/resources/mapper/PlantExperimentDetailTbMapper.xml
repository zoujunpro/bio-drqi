    <insert id="insertBatch">
        insert into plant_experiment_detail_tb(id,pd_num,experiment_num,
        region_num,vector_task_code,seed_num,
        plant_code,generation_code,species_code,
        plant_time,plant_number,experiment_address_code,
        plant_unit,remarks,gene_type,
        create_user_id,create_user_name,create_time)
        values
        <foreach collection="plantExperimentDetailTbCollection" item="item" separator=",">
            (#{item.id,jdbcType=NUMERIC},#{item.pdNum,jdbcType=VARCHAR},#{item.experimentNum,jdbcType=VARCHAR},
            #{item.regionNum,jdbcType=VARCHAR},#{item.vectorTaskCode,jdbcType=VARCHAR},#{item.seedNum,jdbcType=VARCHAR},
            #{item.plantCode,jdbcType=VARCHAR},#{item.generationCode,jdbcType=VARCHAR},#{item.speciesCode,jdbcType=VARCHAR},
            #{item.plantTime,jdbcType=VARCHAR},#{item.plantNumber,jdbcType=NUMERIC},#{item.experimentAddressCode,jdbcType=VARCHAR},
            #{item.plantUnit,jdbcType=VARCHAR},#{item.remarks,jdbcType=VARCHAR},#{item.geneType,jdbcType=VARCHAR},
            #{item.createUserId,jdbcType=NUMERIC},#{item.createUserName,jdbcType=VARCHAR},#{item.createTime,jdbcType=TIMESTAMP})
        </foreach>
    </insert>
</mapper>

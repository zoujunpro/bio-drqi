<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bio.drqi.mapper.PlantExperimentDetailTbMapper">

    <resultMap id="BaseResultMap" type="com.bio.drqi.domain.PlantExperimentDetailTb">
            <id property="id" column="id" jdbcType="INTEGER"/>
            <result property="pdNum" column="pd_num" jdbcType="VARCHAR"/>
            <result property="experimentNum" column="experiment_num" jdbcType="VARCHAR"/>
            <result property="regionNum" column="region_num" jdbcType="VARCHAR"/>
            <result property="vectorTaskCode" column="vector_task_code" jdbcType="VARCHAR"/>
            <result property="seedNum" column="seed_num" jdbcType="VARCHAR"/>
            <result property="plantCode" column="plant_code" jdbcType="VARCHAR"/>
            <result property="generationCode" column="generation_code" jdbcType="VARCHAR"/>
            <result property="speciesCode" column="species_code" jdbcType="VARCHAR"/>
            <result property="plantTime" column="plant_time" jdbcType="VARCHAR"/>
            <result property="plantNumber" column="plant_number" jdbcType="INTEGER"/>
            <result property="experimentAddressCode" column="experiment_address_code" jdbcType="VARCHAR"/>
            <result property="plantUnit" column="plant_unit" jdbcType="VARCHAR"/>
            <result property="remarks" column="remarks" jdbcType="VARCHAR"/>
            <result property="geneType" column="gene_type" jdbcType="VARCHAR"/>
            <result property="createUserId" column="create_user_id" jdbcType="INTEGER"/>
            <result property="createUserName" column="create_user_name" jdbcType="VARCHAR"/>
            <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>

    <sql id="Base_Column_List">
        id,pd_num,experiment_num,
        region_num,vector_task_code,seed_num,
        plant_code,generation_code,species_code,
        plant_time,plant_number,experiment_address_code,
        plant_unit,remarks,gene_type,
        create_user_id,create_user_name,create_time

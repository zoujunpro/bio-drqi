<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bio.drqi.mapper.SeedModifyLogMapper">

    <resultMap id="BaseResultMap" type="com.bio.drqi.domain.SeedModifyLog">
            <id property="id" column="id" jdbcType="INTEGER" />
            <result property="seedNum" column="seed_num" jdbcType="VARCHAR" />
            <result property="fieldCode" column="field_code" jdbcType="VARCHAR" />
            <result property="fieldName" column="field_name" jdbcType="VARCHAR" />
            <result property="oldFieldValue" column="old_field_value" jdbcType="VARCHAR" />
            <result property="newFieldName" column="new_field_name" jdbcType="VARCHAR" />
            <result property="createTime" column="create_time" jdbcType="TIMESTAMP" />
            <result property="createUserId" column="create_user_id" jdbcType="INTEGER" />
            <result property="createUserName" column="create_user_name" jdbcType="VARCHAR" />
    </resultMap>

    <sql id="Base_Column_List">
        id,seed_num,field_code,field_name,old_field_value,new_field_name,
        create_time,create_user_id,create_user_name
    </sql>

    <insert id="insertBatch">
        insert into seed_modify_log(seed_num,field_code,field_name,old_field_value,new_field_name,
        create_time,create_user_id,create_user_name)
        values
        <foreach collection="seedModifyLogCollection" item="item" separator=",">
            (#{item.seedNum,jdbcType=VARCHAR},#{item.fieldCode,jdbcType=VARCHAR},#{item.fieldName,jdbcType=VARCHAR},
            #{item.oldFieldValue,jdbcType=VARCHAR},#{item.newFieldName,jdbcType=VARCHAR},
            #{item.createTime,jdbcType=TIMESTAMP},#{item.createUserId,jdbcType=INTEGER},#{item.createUserName,jdbcType=VARCHAR})
        </foreach>
    </insert>
</mapper>

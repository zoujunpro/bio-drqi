<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bio.drqi.mapper.SeedQualityCheckDtlTbMapper">

    <resultMap id="BaseResultMap" type="com.bio.drqi.domain.SeedQualityCheckDtlTb">
        <id property="id" column="id" jdbcType="INTEGER"/>
        <result property="seedNum" column="seed_num" jdbcType="VARCHAR"/>
        <result property="checkResult" column="check_result" jdbcType="VARCHAR"/>
        <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
        <result property="createUser" column="create_user" jdbcType="VARCHAR"/>
    </resultMap>

    <sql id="Base_Column_List">
        id
        ,seed_num,check_result,
        create_time,create_user
    </sql>
    <select id="selectSelective" parameterType="com.bio.drqi.domain.SeedQualityCheckDtlTb" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from
        seed_quality_check_dtl_tb
        <where>
            <if test="seedNum != null and seedNum!=''">and seed_num=#{seedNum,jdbcType=VARCHAR}</if>
            <if test="checkResult != null">and check_result=#{checkResult,jdbcType=VARCHAR}</if>
            <if test="createTime != null">and create_time=#{createTime,jdbcType=TIMESTAMP}</if>
            <if test="createUser != null">and create_user=#{createUser,jdbcType=VARCHAR}</if>
        </where>
        order by id desc
    </select>

</mapper>

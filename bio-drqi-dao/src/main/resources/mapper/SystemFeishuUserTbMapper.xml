<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bio.drqi.mapper.SystemFeishuUserTbMapper">

    <resultMap id="BaseResultMap" type="com.bio.drqi.domain.SystemFeishuUserTb">
            <id property="id" column="id" jdbcType="INTEGER"/>
            <result property="feishuUserId" column="feishu_user_id" jdbcType="VARCHAR"/>
            <result property="localUserId" column="local_user_id" jdbcType="INTEGER"/>
            <result property="departmentId" column="department_id" jdbcType="VARCHAR"/>
            <result property="feishuStatus" column="feishu_status" jdbcType="VARCHAR"/>
            <result property="managerId" column="manager_id" jdbcType="VARCHAR"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,feishu_user_id,local_user_id,
        department_id,feishu_status,manager_id
    </sql>
    <select id="selectOneByLocalUserId" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from system_feishu_user_tb
        where
        local_user_id = #{localUserId,jdbcType=NUMERIC}
    </select>
</mapper>

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bio.drqi.mapper.SystemMenuTbMapper">
    <resultMap id="BaseResultMap" type="com.bio.drqi.domain.SystemMenuTb">
        <id column="id" jdbcType="INTEGER" property="id"/>
        <result column="parent_id" jdbcType="INTEGER" property="parentId"/>
        <result column="system_id" jdbcType="INTEGER" property="systemId"/>
        <result column="front_permission_code" jdbcType="VARCHAR" property="frontPermissionCode"/>
        <result column="menu_name" jdbcType="VARCHAR" property="menuName"/>
        <result column="component_path" jdbcType="VARCHAR" property="componentPath"/>
        <result column="menu_type" jdbcType="VARCHAR" property="menuType"/>
        <result column="menu_status" jdbcType="VARCHAR" property="menuStatus"/>
        <result column="menu_icon" jdbcType="VARCHAR" property="menuIcon"/>
        <result column="order_num" jdbcType="INTEGER" property="orderNum"/>
        <result column="create_time" jdbcType="TIMESTAMP" property="createTime"/>
        <result column="update_time" jdbcType="TIMESTAMP" property="updateTime"/>
        <result column="back_permission_code" jdbcType="VARCHAR" property="backPermissionCode"/>
    </resultMap>
    <sql id="Base_Column_List">
        id
        , parent_id, system_id, front_permission_code, menu_name, component_path, menu_type,
    menu_status, menu_icon, order_num, create_time, update_time, back_permission_code
    </sql>

    <select id="queryMenuByUserId" parameterType="java.lang.Integer" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from system_menu_tb
        where
        id in(select menu_id from system_role_menu_ref where role_id in(select role_id from system_user_role_ref where
        user_id=#{userId,jdbcType=INTEGER}))
        and system_id in(select system_id from system_user_sys_ref where user_id=#{userId,jdbcType=INTEGER})
        and menu_status='Y'
    </select>
    <select id="selectAllBySystemId" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from system_menu_tb
        where
        system_id = #{systemId,jdbcType=NUMERIC}
    </select>
    <select id="selectAllByParentId" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from system_menu_tb
        where
        parent_id = #{parentId,jdbcType=NUMERIC}
    </select>
</mapper>
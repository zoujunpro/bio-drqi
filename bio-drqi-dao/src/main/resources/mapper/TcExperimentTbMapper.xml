<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bio.drqi.mapper.TcExperimentTbMapper">

    <resultMap id="BaseResultMap" type="com.bio.drqi.domain.TcExperimentTb">
            <id property="id" column="id" jdbcType="INTEGER"/>
            <result property="vectorTaskCodes" column="vector_task_codes" jdbcType="VARCHAR"/>
            <result property="speciesCode" column="species_code" jdbcType="VARCHAR"/>
            <result property="speciesName" column="species_name" jdbcType="VARCHAR"/>
            <result property="fileUrl" column="file_url" jdbcType="VARCHAR"/>
            <result property="experimentGoal" column="experiment_goal" jdbcType="VARCHAR"/>
            <result property="experimentAddressCode" column="experiment_address_code" jdbcType="VARCHAR"/>
            <result property="applyUserName" column="apply_user_name" jdbcType="VARCHAR"/>
            <result property="applyUserId" column="apply_user_id" jdbcType="INTEGER"/>
            <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
            <result property="experimentNum" column="experiment_num" jdbcType="VARCHAR"/>
            <result property="taskNum" column="task_num" jdbcType="VARCHAR"/>
            <result property="designUrl" column="design_url" jdbcType="VARCHAR"/>
            <result property="sampleCodePrefix" column="sample_code_prefix" jdbcType="VARCHAR"/>
            <result property="nextSampleNumber" column="next_sample_number" jdbcType="VARCHAR"/>
            <result property="experimentStatus" column="experiment_status" jdbcType="VARCHAR"/>
            <result property="harvestApplyNum" column="harvest_apply_num" jdbcType="VARCHAR"/>
            <result property="experimentType" column="experiment_type" jdbcType="VARCHAR"/>
            <result property="breedingFlag" column="breeding_flag" jdbcType="VARCHAR"/>
            <result property="pdImplementCodes" column="pd_implement_codes" jdbcType="VARCHAR"/>


    </resultMap>

    <sql id="Base_Column_List">
        id,vector_task_codes,pd_implement_codes,
        species_code,species_name,file_url,
        experiment_goal,experiment_address_code,apply_user_name,
        apply_user_id,create_time,experiment_num,
        task_num,design_url,sample_code_prefix,next_sample_number,experiment_status, harvest_apply_num,experiment_type,breeding_flag
    </sql>
    <select id="selectSelective" resultMap="BaseResultMap" parameterType="com.bio.drqi.domain.TcExperimentTb">
        select
        <include refid="Base_Column_List"/>
        from tc_experiment_tb
        <where>
            <if test="vectorTaskCodes != null and vectorTaskCodes!=''">and vector_task_codes  LIKE  CONCAT('%',#{vectorTaskCodes,jdbcType=VARCHAR},'%')</if>
            <if test="speciesCode != null and speciesCode!=''">and species_code=#{speciesCode,jdbcType=VARCHAR}</if>
            <if test="speciesName != null and speciesName!='' ">and species_name=#{speciesName,jdbcType=VARCHAR}</if>
            <if test="fileUrl != null">file_url=#{fileUrl,jdbcType=VARCHAR}</if>
            <if test="experimentGoal != null">and experiment_goal=#{experimentGoal,jdbcType=VARCHAR}</if>
            <if test="experimentAddressCode != null">and experiment_address_code=#{experimentAddressCode,jdbcType=VARCHAR}</if>
            <if test="applyUserName != null">and apply_user_name=#{applyUserName,jdbcType=VARCHAR}</if>
            <if test="applyUserId != null">and apply_user_id=#{applyUserId,jdbcType=NUMERIC}</if>
            <if test="createTime != null">and create_time=#{createTime,jdbcType=TIMESTAMP}</if>
            <if test="experimentNum != null and experimentNum!=''">and experiment_num=#{experimentNum,jdbcType=VARCHAR}</if>
            <if test="taskNum != null">and task_num=#{taskNum,jdbcType=VARCHAR}</if>
            <if test="experimentStatus != null and experimentStatus!=''">and harvest_apply_num=#{experimentStatus,jdbcType=VARCHAR}</if>
            <if test="experimentType != null and experimentType!=''">and experiment_type=#{experimentType,jdbcType=VARCHAR}</if>
            <if test="pdImplementCodes != null and pdImplementCodes!=''">and pd_implement_codes=#{pdImplementCodes,jdbcType=VARCHAR}</if>

        </where>
        order by id desc
    </select>
    <select id="selectAllByPollinationNumIsNullOrderByIdDesc" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from tc_experiment_tb
        where
        pollination_num is null
        order by id desc
    </select>

    <select id="selectOneByExperimentNum" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from tc_experiment_tb
        where
        experiment_num = #{experimentNum,jdbcType=VARCHAR}
    </select>
    <select id="selectMaxSampleCodePerfix" resultType="java.lang.String">
        select max(sample_code_prefix) from tc_experiment_tb
    </select>
    <select id="selectAllByExperimentStatusOrderByIdDesc" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from tc_experiment_tb
        where
        experiment_status = #{experimentStatus,jdbcType=VARCHAR}
        order by id desc
    </select>
    <select id="selectAllByExperimentStatusAndHarvestApplyNumIsNullOrderByIdDesc" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from tc_experiment_tb
        where
        experiment_status = #{experimentStatus,jdbcType=VARCHAR}
        AND harvest_apply_num is null
        order by id desc
    </select>
    <select id="selectAllByExperimentNumInAndExperimentTypeLike" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from tc_experiment_tb
        where
        experiment_num in
        <foreach collection="experimentNumList" item="item" open="(" close=")" separator=",">
            #{item,jdbcType=VARCHAR}
        </foreach>
        AND experiment_type like CONCAT('%',#{experimentType,jdbcType=VARCHAR},'%')
    </select>

</mapper>

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bio.drqi.mapper.TcSampleLayoutTbMapper">

    <resultMap id="BaseResultMap" type="com.bio.drqi.domain.TcSampleLayoutTb">
            <id property="id" column="id" jdbcType="INTEGER"/>
            <result property="applyNo" column="apply_no" jdbcType="VARCHAR"/>
            <result property="singleContent" column="single_content" jdbcType="VARCHAR"/>
            <result property="plateContent" column="plate_content" jdbcType="VARCHAR"/>
            <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,apply_no,single_content,
        plate_content,create_time
    </sql>
    <select id="selectOneByApplyNo" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from tc_sample_layout_tb
        where
        apply_no = #{applyNo,jdbcType=VARCHAR}
    </select>
</mapper>

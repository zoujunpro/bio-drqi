ARG BASE_IMAGE=nacos/nacos-server:v2.3.2
FROM ${BASE_IMAGE}

WORKDIR /app

COPY target/bio-drqi-es-1.0-SNAPSHOT.jar /app/app.jar

ENV TZ=Asia/Shanghai
ENV SERVER_PORT=18094
ENV DEBUG_PORT=28094
ENV JAVA_OPTS="-Xmx768m -Xms768m -Xmn384m -Xss256k"

EXPOSE 18094 28094

ENTRYPOINT ["sh", "-c", "java ${JAVA_OPTS} -agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=${DEBUG_PORT} -jar /app/app.jar"]

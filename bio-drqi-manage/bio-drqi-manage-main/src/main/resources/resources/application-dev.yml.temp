base:
  config:
    mysql:
      hostname: 124.222.254.239
      port: 3306
      username: root
      password: 123456
      database: bio_cer_test
    redis:
      host: 124.222.254.239
      port: 6379
      password: redis123
spring:
  datasource:
    url: jdbc:mysql://${base.config.mysql.hostname}:${base.config.mysql.port}/${base.config.mysql.database}?useUnicode=true&characterEncoding=utf-8
    username: ${base.config.mysql.username}
    password: ${base.config.mysql.password}
    driver-class-name: com.mysql.cj.jdbc.Driver
    type: com.alibaba.druid.pool.DruidDataSource
    druid:
      initial-size: 10
      max-active: 50
      min-idle: 10
      max-wait: 3600
      validation-query: select 1
      validation-query-timeout: 1000
      test-on-borrow: false
      test-on-return: false
      test-while-idle: true
      poolPreparedStatements: true
      time-between-eviction-runs-millis: 60000
      min-evictable-idle-time-millis: 300000
  redis:
    database: 10
    host: ${base.config.redis.host}
    port: ${base.config.redis.port}
    password: ${base.config.redis.password}
    lettuce:
      pool:
        min-idle: 0
        max-idle: 8
        max-wait: -1
        max-active: 8
    timeout: 3000000
  jackson:
    time-zone: GMT+8
    date-format: yyyy-MM-dd HH:mm:ss
    defaultPropertyInclusion: ALWAYS
mybatis:
  type-aliases-package: com.bio.cer.manage
  mapper-locations: classpath:/mapper/*.xml
pagehelper:
  reasonable: true
  helper-dialect: mysql
  support-methods-arguments: true
  params: count=countSql

logging:
  config: classpath:log/logback-dev.xml
log:
  path: /data/service/cer/logs